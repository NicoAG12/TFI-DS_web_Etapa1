# ─── Base de Datos ───
POSTGRES_USER=tfi_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=tfi_production

# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── RabbitMQ ───
RABBITMQ_USER=tfi_prod
RABBITMQ_PASS=CHANGE_ME_RABBITMQ_PASSWORD

# ─── Seguridad ───
JWT_SECRET=CHANGE_ME_MINIMO_32_CARACTERES_ALEATORIOS

# ─── Docker Registry ───
REGISTRY=ghcr.io/mi-organizacion
TAG=latest

# ─── Cloud Provider ───
# Opciones: hetzner | aws
CLOUD_PROVIDER=hetzner
