flowchart TB
  user["Usuarios / Recepcionista"] --> cdn["CloudFront + S3<br/>Frontend React"]
  user --> alb["Application Load Balancer"]
  alb --> ingress["Ingress Controller<br/>EKS"]
  ingress --> gateway["API Gateway xN"]

  subgraph eks["EKS - Kubernetes Cluster"]
    gateway --> auth["auth-service"]
    gateway --> core["core-service"]
    gateway --> ventas["ventas-service"]
    gateway --> torneos["torneos-service"]
    gateway --> match["matchmaking-service"]
    gateway --> query["query-service"]
    gateway --> saga["saga-orchestrator"]
    workers["event workers xN"]
  end

  gateway --> mq["Amazon MQ / RabbitMQ<br/>commands + events + DLQ"]
  saga --> mq
  workers --> mq
  mq --> workers

  query --> redis["ElastiCache Redis<br/>cache TTL"]
  match --> redis
  query --> replica["RDS PostgreSQL<br/>Read Replica"]
  core --> primary["RDS PostgreSQL<br/>Primary"]
  ventas --> primary
  torneos --> primary
  auth --> primary
  primary --> replica

  eks --> ecr["ECR<br/>Docker images"]
  eks --> cw["CloudWatch<br/>logs + metrics + alarms"]
  terraform["Terraform<br/>S3 state + DynamoDB lock"] --> alb
  terraform --> eks
  terraform --> primary
  terraform --> redis
  terraform --> mq
