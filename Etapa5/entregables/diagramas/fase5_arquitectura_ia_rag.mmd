flowchart LR
  user["Usuario / Frontend React"] --> gateway["API Gateway"]

  gateway --> ai["ai-assistant-service"]
  ai --> vdb["Base vectorial<br/>Pinecone / Chroma / Milvus"]
  ai --> llm["Proveedor LLM<br/>API externa"]
  ai --> gateway

  gateway --> core["core-service<br/>turnos / canchas / pagos"]
  gateway --> match["matchmaking-service"]
  gateway --> torneos["torneos-service"]

  core --> broker["RabbitMQ<br/>commands + events + DLQ"]
  match --> broker
  torneos --> broker

  broker --> embed["embedding-worker"]
  embed --> embapi["Embeddings API"]
  embed --> vdb

  match --> notifEvent["notificacion.personalizar.solicitada"]
  notifEvent --> broker
  broker --> notifWorker["notification-ai-worker"]
  notifWorker --> llm
  notifWorker --> fallback["Fallback plantilla estatica"]
  notifWorker --> notifOut["notificacion.generada"]
  fallback --> notifOut
  notifOut --> broker
  broker --> websocket["WebSocket / Email / Push"]

  ai --> redis["Redis<br/>cache de consultas frecuentes"]
  ai --> obs["Observabilidad<br/>latencia / tokens / costo / errores"]
  embed --> obs
  notifWorker --> obs

  subgraph "Regla de negocio"
    safe["Reservas y pagos no dependen de IA"]
  end
  core --> safe

